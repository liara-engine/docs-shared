<!DOCTYPE HTML>

{{!--
    Liara Engine — mdBook template (index.hbs)

    This template replaces mdBook's default index.hbs to integrate the
    shared Liara navbar at the top of every user-guide page. It is based
    on mdBook's default template but reorganized so that:
        1. The Liara navbar appears at the very top of the body.
        2. The mdBook sidebar slides in below the navbar (not above it).
        3. Theme/a11y preferences are applied synchronously to prevent
           flash of unstyled content.

    Handlebars tokens (do not remove or rename):
        {{ language }}             current language code
        {{ title }}                page title
        {{ description }}          page description
        {{ path_to_root }}         relative path to the book root
        {{ chapter_title }}        chapter title for <title>
        {{ default_theme }}        configured default theme
        {{ preferred_dark_theme }} dark theme name
        {{ #toc }}{{ /toc }}       sidebar TOC content
        {{{ content }}}            the rendered chapter HTML
        {{ #if ... }}              conditional blocks for optional features
--}}

<html lang="{{ language }}" class="sidebar-visible no-js {{ default_theme }}">
<head>
<meta charset="UTF-8">
<title>{{ chapter_title }} - {{ book_title }}</title>
{{#if is_print }}
<meta name="robots" content="noindex">
{{/if}}
{{#if base_url}}
<base href="{{ base_url }}">
{{/if}}
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="{{ description }}">
<meta name="theme-color" content="#FFFAFC">

{{#if favicon_svg}}
<link rel="icon" href="{{ path_to_root }}favicon.svg">
{{/if}}
{{#if favicon_png}}
<link rel="shortcut icon" href="{{ path_to_root }}favicon.png">
{{/if}}
<link rel="stylesheet" href="{{ path_to_root }}css/variables.css">
<link rel="stylesheet" href="{{ path_to_root }}css/general.css">
<link rel="stylesheet" href="{{ path_to_root }}css/chrome.css">
{{#if print_enable}}
<link rel="stylesheet" href="{{ path_to_root }}css/print.css" media="print">
{{/if}}

<!-- Fonts: Inter, JetBrains Mono, OpenDyslexic -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/opendyslexic@1.0.4/opendyslexic-regular.css">

<!-- mdBook's built-in highlight.css (we ship our own override below) -->
<link rel="stylesheet" href="{{ path_to_root }}highlight.css">
<link rel="stylesheet" href="{{ path_to_root }}tomorrow-night.css">
<link rel="stylesheet" href="{{ path_to_root }}ayu-highlight.css">

<!-- Liara design system (loaded AFTER mdBook's own CSS so we override) -->
<link rel="stylesheet" href="{{ path_to_root }}design-tokens.css">
<link rel="stylesheet" href="{{ path_to_root }}navbar.css">
<link rel="stylesheet" href="{{ path_to_root }}custom.css">

{{#each additional_css}}
<link rel="stylesheet" href="{{ ../path_to_root }}{{ this }}">
{{/each}}

{{#if mathjax_support}}
<script async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
{{/if}}
</head>
<body class="sidebar-visible">
<!-- Provide site root and default themes for the JS to consume -->
<div id="body-container">

<!-- Apply theme/a11y prefs synchronously, before mdBook's own theme JS runs -->
<script>
(function () {
    try {
        var t = localStorage.getItem("liara-theme");
        if (t === "light" || t === "dark") {
            document.documentElement.setAttribute("data-liara-theme", t);
        }
        if (localStorage.getItem("liara-a11y-dyslexia") === "true") {
            document.documentElement.setAttribute("data-liara-a11y-dyslexia", "true");
        }
        // Bridge to mdBook's own theme system: align mdBook's `class` on <html>
        // with our chosen theme, so its native styles also follow.
        var mdbookTheme = (t === "dark") ? "{{ preferred_dark_theme }}"
                       : (t === "light") ? "{{ default_theme }}"
                       : null;
        if (mdbookTheme) {
            document.documentElement.classList.remove(
                "light", "rust", "coal", "navy", "ayu");
            document.documentElement.classList.add(mdbookTheme);
        }
    } catch (e) { /* localStorage unavailable, fall back to defaults */ }
})();
</script>

<!-- ====================================================================
     LIARA NAVBAR — mirrors docs-shared/navbar/navbar.html
     ==================================================================== -->
<nav id="liara-navbar" class="liara-navbar" aria-label="Documentation navigation">
    <div class="liara-navbar__inner">
        <a class="liara-navbar__brand" href="https://liara-engine.github.io/" aria-label="Liara Engine home">
            <svg class="liara-navbar__logo" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="var(--liara-brand-primary)"/>
                <circle cx="12" cy="12" r="4" fill="var(--liara-brand-primary-dark)"/>
            </svg>
            <span class="liara-navbar__brand-name">Liara Engine</span>
        </a>
        <ul class="liara-navbar__modules" role="list">
            <li><a class="liara-navbar__module" data-liara-module="user" href="https://liara-engine.github.io/user/dev/">User guide</a></li>
            <li><a class="liara-navbar__module" data-liara-module="interfaces" href="https://liara-engine.github.io/liara-interfaces/dev/">Interfaces</a></li>
            <li><a class="liara-navbar__module" data-liara-module="core" href="https://liara-engine.github.io/liara-core/dev/">Core</a></li>
            <li><a class="liara-navbar__module" data-liara-module="renderer" href="https://liara-engine.github.io/liara-renderer/dev/">Renderer</a></li>
        </ul>
        <div class="liara-navbar__spacer"></div>
        <div class="liara-navbar__version">
            <button class="liara-navbar__version-trigger" type="button" aria-haspopup="listbox" aria-expanded="false" aria-label="Switch documentation version">
                <span class="liara-navbar__version-label" data-liara-version-label>dev</span>
                <svg class="liara-navbar__version-caret" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
                    <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <ul class="liara-navbar__version-menu" role="listbox" data-liara-version-menu hidden></ul>
        </div>
        <div class="liara-navbar__actions">
            <button class="liara-navbar__action" type="button" data-liara-theme-toggle aria-label="Toggle color theme" title="Toggle color theme">
                <svg class="liara-navbar__icon liara-navbar__icon--system" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M8 21h8M12 18v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <svg class="liara-navbar__icon liara-navbar__icon--light" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <svg class="liara-navbar__icon liara-navbar__icon--dark" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/></svg>
            </button>
            <button class="liara-navbar__action liara-navbar__action--text" type="button" data-liara-a11y-toggle aria-label="Toggle dyslexia-friendly mode" aria-pressed="false" title="Dyslexia-friendly mode">
                <span aria-hidden="true">Aa</span>
            </button>
            <a class="liara-navbar__action" data-liara-github href="https://github.com/liara-engine/liara" aria-label="View on GitHub" title="View on GitHub" target="_blank" rel="noopener">
                <svg class="liara-navbar__icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85V21c0 .27.16.58.67.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2z"/></svg>
            </a>
        </div>
        <button class="liara-navbar__menu-toggle" type="button" data-liara-menu-toggle aria-label="Open menu" aria-expanded="false">
            <span class="liara-navbar__menu-toggle-bar"></span>
            <span class="liara-navbar__menu-toggle-bar"></span>
            <span class="liara-navbar__menu-toggle-bar"></span>
        </button>
    </div>
</nav>

<!-- Load the Liara navbar logic AFTER the navbar markup is in the DOM -->
<script defer src="{{ path_to_root }}navbar.js"></script>

<!-- ====================================================================
     mdBook layout — sidebar + content
     ==================================================================== -->

<!-- Provide site root for the JS to consume -->
<input type="hidden" id="MDBOOK_OUTPUT" value="{{ path_to_root }}">
{{#if mathjax_support}}<input type="hidden" id="MathJax_Support" value="true">{{/if}}

<!-- Hide / unhide sidebar before it is displayed -->
<script>
    var path_to_root = "{{ path_to_root }}";
    var default_theme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "{{ preferred_dark_theme }}" : "{{ default_theme }}";
</script>

<!-- Set the theme before any content is loaded, prevents flash -->
<script>
    try {
        var theme = localStorage.getItem('mdbook-theme');
        var sidebar = localStorage.getItem('mdbook-sidebar');

        if (theme.startsWith('"') && theme.endsWith('"')) {
            localStorage.setItem('mdbook-theme', theme.slice(1, theme.length - 1));
        }

        if (sidebar.startsWith('"') && sidebar.endsWith('"')) {
            localStorage.setItem('mdbook-sidebar', sidebar.slice(1, sidebar.length - 1));
        }
    } catch (e) { }
</script>

<!-- Sidebar -->
<nav id="sidebar" class="sidebar" aria-label="Table of contents">
    <div class="sidebar-scrollbox">
        {{#toc}}{{/toc}}
    </div>
    <div id="sidebar-resize-handle" class="sidebar-resize-handle">
        <div class="sidebar-resize-indicator"></div>
    </div>
</nav>

<!-- Track and set sidebar scroll position -->
<script>
    var sidebarScrollbox = document.querySelector('#sidebar .sidebar-scrollbox');
    sidebarScrollbox.addEventListener('click', function(e) {
        if (e.target.tagName === 'A') {
            sessionStorage.setItem('sidebar-scroll', sidebarScrollbox.scrollTop);
        }
    }, { passive: true });
    var sidebarScrollTop = sessionStorage.getItem('sidebar-scroll');
    sessionStorage.removeItem('sidebar-scroll');
    if (sidebarScrollTop) {
        sidebarScrollbox.scrollTop = sidebarScrollTop;
    } else {
        var activeSection = document.querySelector('#sidebar .active');
        if (activeSection) {
            activeSection.scrollIntoView({ block: 'center' });
        }
    }
</script>

<div id="page-wrapper" class="page-wrapper">

    <div class="page">
        {{> header}}
        <div id="menu-bar-hover-placeholder"></div>
        <div id="menu-bar" class="menu-bar sticky">
            <div class="left-buttons">
                <label id="sidebar-toggle" class="icon-button" for="sidebar-toggle-anchor" title="Toggle Table of Contents" aria-label="Toggle Table of Contents" aria-controls="sidebar">
                    <i class="fa fa-bars"></i>
                </label>
                {{#if print_enable}}
                <a href="{{ path_to_root }}print.html" title="Print this book" aria-label="Print this book">
                    <i id="print-button" class="fa fa-print"></i>
                </a>
                {{/if}}
                {{#if search_enabled}}
                <button id="search-toggle" class="icon-button" type="button" title="Search. (Shortcut: s)" aria-label="Toggle Searchbar" aria-expanded="false" aria-keyshortcuts="S" aria-controls="searchbar">
                    <i class="fa fa-search"></i>
                </button>
                {{/if}}
            </div>

            <h1 class="menu-title">{{ book_title }}</h1>

            <div class="right-buttons">
                {{#if git_repository_url}}
                <a href="{{git_repository_url}}" title="Git repository" aria-label="Git repository">
                    <i id="git-repository-button" class="fa {{git_repository_icon}}"></i>
                </a>
                {{/if}}
                {{#if git_repository_edit_url}}
                <a href="{{git_repository_edit_url}}" title="Suggest an edit" aria-label="Suggest an edit">
                    <i id="git-edit-button" class="fa fa-edit"></i>
                </a>
                {{/if}}
            </div>
        </div>

        {{#if search_enabled}}
        <div id="search-wrapper" class="hidden">
            <form id="searchbar-outer" class="searchbar-outer">
                <input type="search" id="searchbar" name="searchbar" placeholder="Search this book ..." aria-controls="searchresults-outer" aria-describedby="searchresults-header">
            </form>
            <div id="searchresults-outer" class="searchresults-outer hidden">
                <div id="searchresults-header" class="searchresults-header"></div>
                <ul id="searchresults"></ul>
            </div>
        </div>
        {{/if}}

        <!-- Apply ARIA attributes after the sidebar and the sidebar toggle button are added to the DOM -->
        <script>
            document.getElementById('sidebar-toggle-anchor').addEventListener('change', function () {
                document.getElementById('sidebar-toggle').setAttribute('aria-expanded', this.checked.toString());
                document.getElementById('sidebar').setAttribute('aria-hidden', (!this.checked).toString());
                Array.from(document.querySelectorAll('#sidebar a')).forEach(function (link) {
                    link.setAttribute('tabIndex', this.checked ? 0 : -1);
                }.bind(this));
            });
        </script>

        <div id="content" class="content">
            <main>
                {{{ content }}}
            </main>

            <nav class="nav-wrapper" aria-label="Page navigation">
                {{#if previous}}
                <a rel="prev" href="{{ ../path_to_root }}{{ link }}" class="mobile-nav-chapters previous" title="Previous chapter" aria-label="Previous chapter" aria-keyshortcuts="Left">
                    <i class="fa fa-angle-left"></i>
                </a>
                {{/if}}
                {{#if next}}
                <a rel="next prefetch" href="{{ ../path_to_root }}{{ link }}" class="mobile-nav-chapters next" title="Next chapter" aria-label="Next chapter" aria-keyshortcuts="Right">
                    <i class="fa fa-angle-right"></i>
                </a>
                {{/if}}
                <div style="clear: both"></div>
            </nav>
        </div>
    </div>

    <nav class="nav-wide-wrapper" aria-label="Page navigation">
        {{#if previous}}
        <a rel="prev" href="{{ ../path_to_root }}{{ link }}" class="nav-chapters previous" title="Previous chapter" aria-label="Previous chapter" aria-keyshortcuts="Left">
            <i class="fa fa-angle-left"></i>
        </a>
        {{/if}}
        {{#if next}}
        <a rel="next prefetch" href="{{ ../path_to_root }}{{ link }}" class="nav-chapters next" title="Next chapter" aria-label="Next chapter" aria-keyshortcuts="Right">
            <i class="fa fa-angle-right"></i>
        </a>
        {{/if}}
    </nav>
</div>

{{#if live_reload_endpoint}}
<!-- Livereload script (if served using the cli tool) -->
<script>
    const wsAddress = "{{{live_reload_endpoint}}}";
    const socket = new WebSocket(wsAddress);
    socket.onmessage = function (event) {
        if (event.data === "reload") socket.close();
    };
    window.onbeforeunload = function() { socket.close(); }
</script>
{{/if}}

{{#if google_analytics}}
<!-- Google Analytics Tag -->
<script>
    var localAddrs = ["localhost", "127.0.0.1", ""];
    if ((!locationProtocol.startsWith('http') || localAddrs.indexOf(window.location.hostname) === -1)) {
        (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
        })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');
        ga('create', '{{google_analytics}}', 'auto');
        ga('send', 'pageview');
    }
</script>
{{/if}}

{{#if playground_line_numbers}}
<script>
    window.playground_line_numbers = true;
</script>
{{/if}}

{{#if playground_copyable}}
<script>
    window.playground_copyable = true;
</script>
{{/if}}

{{#if playground_js}}
<script src="{{ path_to_root }}ace.js"></script>
<script src="{{ path_to_root }}editor.js"></script>
<script src="{{ path_to_root }}mode-rust.js"></script>
<script src="{{ path_to_root }}theme-dawn.js"></script>
<script src="{{ path_to_root }}theme-tomorrow_night.js"></script>
{{/if}}

{{#if search_js}}
<script src="{{ path_to_root }}elasticlunr.min.js"></script>
<script src="{{ path_to_root }}mark.min.js"></script>
<script src="{{ path_to_root }}searcher.js"></script>
{{/if}}

<script src="{{ path_to_root }}clipboard.min.js"></script>
<script src="{{ path_to_root }}highlight.js"></script>
<script src="{{ path_to_root }}book.js"></script>

<!-- Custom JS scripts -->
{{#each additional_js}}
<script src="{{ ../path_to_root }}{{this}}"></script>
{{/each}}

</div>
</body>
</html>